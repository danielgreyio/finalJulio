# Application Configuration
APP_NAME=VentDepot
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ventdepot
DB_USERNAME=ventdepot_user
DB_PASSWORD=your_strong_password

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# Payment Configuration
# Active provider: stripe | paypal | mercadopago
PAYMENT_PROVIDER=stripe

# Stripe
STRIPE_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET=sk_test_your_stripe_secret_key

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Mercado Pago (for Mexico OXXO / cash payments)
MP_ACCESS_TOKEN=TEST-your_mp_access_token
MP_PUBLIC_KEY=TEST-your_mp_public_key

# Email Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your_mailgun_username
MAIL_PASSWORD=your_mailgun_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=VentDepot

# Shipping Configuration
# Active providers (comma-separated): estafeta,dhl
SHIPPING_PROVIDERS=estafeta,dhl

# Estafeta
ESTAFETA_CUSTOMER_NUMBER=your_estafeta_customer_number
ESTAFETA_USER=your_estafeta_user
ESTAFETA_PASSWORD=your_estafeta_password
ESTAFETA_ENVIRONMENT=sandbox

# DHL Mexico
DHL_ACCOUNT=your_dhl_account
DHL_USERNAME=your_dhl_username
DHL_PASSWORD=your_dhl_password
DHL_CUSTOMER_ID=your_dhl_customer_id
DHL_ENVIRONMENT=sandbox

# Security Configuration
# ENCRYPTION_KEY must be at least 32 characters
ENCRYPTION_KEY=your_32_char_minimum_encryption_key_here
JWT_SECRET=your_jwt_secret_key_here
SESSION_LIFETIME=120
SECURITY_SALT=your_random_salt_here
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=debug

# API Configuration
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=3600

# File Storage
STORAGE_DISK=local
STORAGE_ROOT=storage/app/public

# Caching
CACHE_DRIVER=redis
CACHE_PREFIX=ventdepot

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue Configuration
QUEUE_CONNECTION=redis

# Broadcasting
BROADCAST_DRIVER=redis

# Other Services
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"